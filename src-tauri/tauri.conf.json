{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Winsentials",
  "version": "0.1.1",
  "identifier": "com.noktomezo.winsentials",
  "mainBinaryName": "Winsentials",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Winsentials",
        "width": 900,
        "height": 700,
        "resizable": false,
        "maximizable": false,
        "transparent": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Noktomezo/Winsentials/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJDQTUzNTFFQThERkY2MDQKUldRRTl0K29IaldsdkNoR2JkRlhlNGg2QXlrRjhPZEtvM3E3K2JScTM2WVZqSnBCTGgzdFovWXUK"
    }
  },
  "bundle": {
    "publisher": "Noktomezo",
    "shortDescription": "Windows optimization toolbox.",
    "longDescription": "Winsentials is a desktop application for Windows 10 and 11 that lets you tune performance, privacy, appearance, and system behavior through a clean interface built on top of low-level system settings.",
    "copyright": "Copyright © 2026 Noktomezo",
    "active": true,
    "targets": "nsis",
    "createUpdaterArtifacts": true,
    "windows": {
      "nsis": {
        "installerIcon": "../assets/app-installer-logo.ico",
        "headerImage": "../assets/app-installer-header.bmp",
        "sidebarImage": "../assets/app-installer-sidebar.bmp"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
