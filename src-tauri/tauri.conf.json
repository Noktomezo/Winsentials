{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Winsentials",
  "mainBinaryName": "Winsentials",
  "version": "0.1.1",
  "identifier": "com.noktomezo.winsentials",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Winsentials",
        "width": 1000,
        "height": 750,
        "minWidth": 1000,
        "minHeight": 750,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },

  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Noktomezo",
    "category": "Utility",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
