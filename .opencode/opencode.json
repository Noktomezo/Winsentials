{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "memory": {
      "type": "local",
      "command": ["bunx","@modelcontextprotocol/server-memory"],
      "enabled": true,
    },
    "exa": {
      "type": "local",
      "command": ["bunx", "mcp-remote", "https://mcp.exa.ai/mcp"],
      "enabled": true,
    },
    "context7": {
      "type": "local",
      "command": ["bunx", "@upstash/context7-mcp"],
      "enabled": true,
    },
    "shadcn": {
      "type": "local",
      "command": ["bunx", "shadcn", "mcp"],
      "enabled": true,
    }
  }
}
